{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "paths": {
      "declarations/*": ["../declarations/*"],
      "@/backend": ["./src/backendSafe.ts"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "*.config.js",
    "src/backend.ts",
    "src/backend.d.ts"
  ]
}
